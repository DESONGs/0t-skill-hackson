#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path


def _bootstrap() -> None:
    root = Path(__file__).resolve().parents[1]
    src = root / "src"
    vendor_src = root / "vendor" / "skill_enterprise" / "src"
    for path in (vendor_src, src):
        path_str = str(path)
        if path.exists() and path_str not in sys.path:
            sys.path.insert(0, path_str)


def main() -> int:
    _bootstrap()
    from ot_skill_enterprise.root_cli import main as root_main

    return root_main()


if __name__ == "__main__":
    raise SystemExit(main())
