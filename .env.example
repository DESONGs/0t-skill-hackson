# Root-level environment template
# Copy to .env and fill the required real-provider values for normal startup.

# Python
PYTHONPATH=src

# Workspace
OT_DEFAULT_WORKSPACE=.ot-workspace
OT_START_LOCAL_STACK=0
OT_FRONTEND_BIND_HOST=127.0.0.1
OT_FRONTEND_PORT=8090
OT_FRONTEND_WORKSPACE=.ot-workspace

# AVE data plane
AVE_DATA_PROVIDER=ave_rest
AVE_API_KEY=
API_PLAN=pro
AVE_REST_SCRIPT_PATH=vendor/ave_cloud_skill/scripts/ave_data_rest.py
AVE_REST_PYTHON=
AVE_REST_TIMEOUT_SECONDS=30
AVE_DATA_SERVICE_URL=http://127.0.0.1:8080
AVE_DATA_SERVICE_TIMEOUT=10
AVE_DATA_SERVICE_BIND_HOST=127.0.0.1
AVE_DATA_SERVICE_PORT=8080
AVE_USE_DOCKER=true

# Pi / Kimi reflection
OT_RUNTIME_DEFAULT=pi
OT_PI_RUNTIME_ROOT=vendor/pi_runtime
OT_PI_NODE=node
OT_PI_NPM=npm
KIMI_API_KEY=
OT_PI_DEFAULT_MODEL=
OT_PI_REFLECTION_MODEL=kimi-coding/kimi-k2-thinking
OT_PI_REFLECTION_REASONING=medium
OT_PI_REFLECTION_MOCK=0
OT_PI_REFLECTION_TIMEOUT_SECONDS=180
OT_PI_REFLECTION_REQUEST_TIMEOUT_SECONDS=75
OT_PI_REFLECTION_MAX_TOKENS=2200
OT_PI_SESSION_DIR=.ot-workspace/runtime-sessions

# onchainos execution plane
ONCHAINOS_HOME=.ot-workspace/onchainos
OT_ONCHAINOS_CLI_BIN=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OT_ONCHAINOS_LIVE_CAP_USD=10
OT_ONCHAINOS_MIN_LEG_USD=5
OT_ONCHAINOS_APPROVAL_WAIT_RETRIES=6
OT_ONCHAINOS_APPROVAL_WAIT_SECONDS=2

# Optional persistence
OT_DB_DSN=
OT_REDIS_URL=

# Optional blob backend
OT_BLOB_BACKEND=local
OT_BLOB_ROOT=.ot-workspace/blob-store
OT_BLOB_ENDPOINT=
OT_BLOB_BUCKET=
OT_BLOB_REGION=
OT_BLOB_PREFIX=ot-runtime
OT_INLINE_PAYLOAD_LIMIT_BYTES=4096

# Projection cache TTLs
OT_CACHE_TTL_OVERVIEW=30
OT_CACHE_TTL_ACTIVE_RUNS=10
OT_CACHE_TTL_SESSION_SUMMARY=60
OT_CACHE_TTL_EVOLUTION_SUMMARY=30
