    "strategy_spec",
    "execution_intent",
    "risk_filters",
    "timing",
    "sizing",
    "pacing",
    "candidate_generation_thresholds"
  ],
  "worker_actions": [
    "autoresearch.plan_iteration",
    "autoresearch.decide_iteration"
  ],
  "compatible_workflows": [
    "autonomous_research"
  ],
  "metadata": {
    "composes_with": [
      "skill-creation",
      "benchmark",
      "review"
    ],
    "worker_tier": "python-domain-worker"
  }
