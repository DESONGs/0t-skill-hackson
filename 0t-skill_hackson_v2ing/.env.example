# Core runtime
PYTHONPATH=src
OT_RUNTIME_DEFAULT=pi

# AVE provider mode
# mock | auto | ave_rest | real
AVE_DATA_PROVIDER=mock

# AVE credentials
AVE_API_KEY=
API_PLAN=free

# Optional AVE CLI overrides
AVE_REST_SCRIPT_PATH=vendor/ave_cloud_skill/scripts/ave_data_rest.py
AVE_REST_PYTHON=python3
AVE_REST_TIMEOUT_SECONDS=30

# Local data-service runtime
AVE_DATA_SERVICE_URL=http://127.0.0.1:8080
AVE_DATA_SERVICE_TIMEOUT=10
AVE_DATA_SERVICE_BIND_HOST=127.0.0.1
AVE_DATA_SERVICE_PORT=8080

# Workspace defaults
OT_DEFAULT_WORKSPACE=.ot-workspace
OT_START_LOCAL_STACK=0

# Persistence backends
# Local stack example:
# OT_DB_DSN=postgresql://ot:ot_dev_password@127.0.0.1:5432/ot_skill_enterprise
# OT_REDIS_URL=redis://127.0.0.1:6379/0
OT_DB_DSN=
OT_REDIS_URL=

# Blob storage
# local | s3 | minio
OT_BLOB_BACKEND=local
OT_BLOB_ROOT=.ot-workspace/blob-store
OT_BLOB_ENDPOINT=
OT_BLOB_BUCKET=
OT_BLOB_REGION=
OT_BLOB_PREFIX=ot-runtime
OT_INLINE_PAYLOAD_LIMIT_BYTES=4096
# S3/MinIO credentials use the standard AWS SDK environment variables:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Projection cache TTLs
OT_CACHE_TTL_OVERVIEW=30
OT_CACHE_TTL_ACTIVE_RUNS=10
OT_CACHE_TTL_SESSION_SUMMARY=60
OT_CACHE_TTL_EVOLUTION_SUMMARY=30

# Frontend console runtime
OT_FRONTEND_BIND_HOST=127.0.0.1
OT_FRONTEND_PORT=8090
OT_FRONTEND_WORKSPACE=.ot-workspace

# Pi runtime
OT_PI_RUNTIME_ROOT=vendor/pi_runtime
OT_PI_NODE=node
OT_PI_NPM=npm
OT_PI_DEFAULT_MODEL=
OT_PI_REFLECTION_MODEL=
OT_PI_REFLECTION_REASONING=medium
OT_PI_REFLECTION_MOCK=0
OT_PI_SESSION_DIR=.ot-workspace/runtime-sessions
