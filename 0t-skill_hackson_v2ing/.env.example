# Python
PYTHONPATH=src

# Workspace
OT_DEFAULT_WORKSPACE=.ot-workspace
OT_FRONTEND_BIND_HOST=127.0.0.1
OT_FRONTEND_PORT=8090

# AVE data plane
AVE_DATA_PROVIDER=ave_rest
AVE_API_KEY=
API_PLAN=pro
AVE_REST_SCRIPT_PATH=vendor/ave_cloud_skill/scripts/ave_data_rest.py
AVE_REST_PYTHON=python3
AVE_REST_TIMEOUT_SECONDS=30

# Pi / Kimi reflection
OT_RUNTIME_DEFAULT=pi
OT_PI_RUNTIME_ROOT=vendor/pi_runtime
OT_PI_NODE=node
OT_PI_NPM=npm
KIMI_API_KEY=
OT_PI_DEFAULT_MODEL=
OT_PI_REFLECTION_MODEL=kimi-coding/kimi-k2-thinking
OT_PI_REFLECTION_REASONING=medium
OT_PI_REFLECTION_MOCK=0
OT_PI_SESSION_DIR=.ot-workspace/runtime-sessions

# onchainos execution plane
ONCHAINOS_HOME=.ot-workspace/onchainos
OT_ONCHAINOS_CLI_BIN=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OT_ONCHAINOS_LIVE_CAP_USD=10
OT_ONCHAINOS_MIN_LEG_USD=5
OT_ONCHAINOS_APPROVAL_WAIT_RETRIES=6
OT_ONCHAINOS_APPROVAL_WAIT_SECONDS=2

# Optional persistence
OT_DB_DSN=
OT_REDIS_URL=

# Optional blob backend
OT_BLOB_BACKEND=local
OT_BLOB_ROOT=.ot-workspace/blob-store
